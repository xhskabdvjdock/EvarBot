# Discord Bot
TOKEN=

# Discord OAuth (للداشبورد)
CLIENT_ID=
CLIENT_SECRET=

# يجب أن يطابق الرابط في Developer Portal → OAuth2 → Redirects
# مثال على Render: https://اسم-الخدمة.onrender.com/auth/callback
CALLBACK_URL=http://localhost:3000/auth/callback

# جلسات الداشبورد — استخدم قيمة عشوائية طويلة في الإنتاج
